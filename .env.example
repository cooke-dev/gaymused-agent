# --- Network selection (all network values live in src/config.ts presets) ---
# arc-testnet-v2 (default, live now) | giwa-testnet (when Jason delivers the hub)
OPENRAILS_NETWORK=arc-testnet-v2

# Optional per-field overrides (normally leave unset; presets cover Arc)
# OPENRAILS_RPC_URL=
# OPENRAILS_CHAIN_ID=
# OPENRAILS_HUB_ADDRESS=
# OPENRAILS_TOKEN_ADDRESS=
# OPENRAILS_RELAY_URL=
# OPENRAILS_EXPLORER_BASE_URL=

# --- Secrets (never commit .env) ---
# Payer signer used for dev/proving the rail. Testnet-only key.
OPENRAILS_PAYER_PRIVATE_KEY=

# LLM for the agent brain (component 3+)
OPENROUTER_API_KEY=
# Cheap iteration model (current default in dev):
# OPENROUTER_MODEL=google/gemini-3-flash-preview
# OPENROUTER_MODEL=  # for the demo recording, consider a higher-quality model here if the cheap model's explanations aren't demo-ready

# Telegram sidecar (component 7)
TELEGRAM_BOT_TOKEN=
